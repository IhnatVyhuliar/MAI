import os
import json
from google import genai
from google.genai import types
from pydantic import BaseModel, Field

# 1. Define the exact schema using Pydantic
class LawAnalysis(BaseModel):
    relevance_score: int = Field(
        description="Score from 1 to 10 based on accidental violation likelihood and severity."
    )
    reasoning: str = Field(
        description="Brief 1-sentence explanation for the score."
    )
    tourist_summary: str = Field(
        description="Translate the legalese into a simple, actionable warning."
    )
    tags: list[str] = Field(
        description="Categories like Photography, Transit, Drugs, etc."
    )

class LegalTextPrioritizer:
    """
    A class to analyze and prioritize legal paragraphs for a travel app 
    using the modern google-genai SDK.
    """
    
    def __init__(self, api_key: str = None):
        # The new Client automatically picks up the GEMINI_API_KEY environment 
        # variable if no key is explicitly passed.
        self.client = genai.Client(api_key=api_key)
        
        # Upgraded to the modern 2.0 Flash model
        self.model_name = 'gemini-2.0-flash'
        
        system_instruction = """
        You are a legal assistant for a travel app. Read the following paragraph of local law 
        and evaluate its importance to a casual foreign tourist.
        """
        
        # 2. Configuration is now bundled into a GenerateContentConfig object
        self.config = types.GenerateContentConfig(
            temperature=0.1,
            system_instruction=system_instruction,
            response_mime_type="application/json",
            response_schema=LawAnalysis, # Pass the Pydantic model directly
        )

    def analyze_paragraph(self, paragraph: str) -> dict:
        """
        Sends a single paragraph to the LLM and returns a structured dictionary.
        """
        try:
            # 3. generate_content is now called from client.models
            response = self.client.models.generate_content(
                model=self.model_name,
                contents=paragraph,
                config=self.config
            )
            # The output is guaranteed to map to our Pydantic schema
            return json.loads(response.text)
            
        except Exception as e:
            print(f"Error processing paragraph: {e}")
            return {
                "relevance_score": 0,
                "reasoning": "Processing failed.",
                "tourist_summary": "Error analyzing this law.",
                "tags": ["Error"]
            }

    def process_batch(self, paragraphs: list) -> list:
        """
        Processes a list of raw text paragraphs, attaches the original text,
        and returns them sorted by highest relevance score.
        """
        analyzed_laws = []
        
        for p in paragraphs:
            if len(p.strip()) < 15:
                continue
                
            print(f"Analyzing: {p[:30]}...")
            analysis = self.analyze_paragraph(p)
            
            # Attach the original legal text to the result payload
            analysis["original_text"] = p
            analyzed_laws.append(analysis)
            
        # Sort so the most critical laws (score 10) are at the top
        analyzed_laws.sort(key=lambda x: x.get("relevance_score", 0), reverse=True)
        
        return analyzed_laws