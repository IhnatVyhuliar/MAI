import os
import json
import google.generativeai as genai

class ImportanceService:
    """
    A class to analyze and prioritize legal paragraphs for a travel app 
    using the Gemini API.
    """
    
    def __init__(self, api_key: str = None):
        # Fallback to environment variable if no key is passed directly
        self.api_key = api_key or os.environ.get("GEMINI_API_KEY")
        if not self.api_key:
            raise ValueError("A Gemini API key is required to initialize the prioritizer.")
        
        genai.configure(api_key=self.api_key)
        
        # System instructions define the rubric and strict JSON schema
        system_instruction = """
        You are a legal assistant for a travel app. Read the following paragraph of local law 
        and evaluate its importance to a casual foreign tourist.
        
        Score based on:
        1. How likely a tourist is to accidentally violate it.
        2. The severity of the penalty.
        
        You must return ONLY a valid JSON object matching this exact schema:
        {
            "relevance_score": <int 1-10>,
            "reasoning": "<string: brief 1-sentence explanation>",
            "tourist_summary": "<string: translated legalese into a simple warning>",
            "tags": ["<string: categories like Photography, Transit, Drugs>"]
        }
        """
        
        # Initialize the model (using Flash for speed and cost-efficiency on large text)
        self.model = genai.GenerativeModel(
            model_name='gemini-3.5-flash',
            system_instruction=system_instruction
        )

    def analyze_paragraph(self, paragraph: str) -> dict:
        """
        Sends a single paragraph to the LLM and returns a structured dictionary.
        """
        try:
            response = self.model.generate_content(
                paragraph,
                generation_config=genai.GenerationConfig(
                    response_mime_type="application/json",
                    temperature=0.1, # Low temperature ensures consistent, analytical outputs
                )
            )
            # Parse the guaranteed JSON string into a Python dictionary
            return json.loads(response.text)
            
        except Exception as e:
            # Safe fallback if the API errors out or rate limits
            print(f"Error processing paragraph: {e}")
            return {
                "relevance_score": 0,
                "reasoning": "Processing failed.",
                "tourist_summary": "Error analyzing this law.",
                "tags": ["Error"]
            }

    def process_batch(self, paragraphs: list) -> list:
        """
        Takes a list of raw text paragraphs, processes them, attaches the original text,
        and returns them sorted by highest relevance score.
        """
        analyzed_laws = []
        
        for p in paragraphs:
            # Skip empty lines or tiny fragments
            if len(p.strip()) < 15:
                continue
                
            print(f"Analyzing: {p[:30]}...")
            analysis = self.analyze_paragraph(p)
            
            # Attach the original legal text to the result payload
            analysis["original_text"] = p
            analyzed_laws.append(analysis)
            
        # Sort the final list so the most critical laws (score 10) are at the top
        analyzed_laws.sort(key=lambda x: x.get("relevance_score", 0), reverse=True)
        
        return analyzed_laws